# --- Investown target ---
BASE_URL=https://dev.investown.net

# --- Test account ---
# Use a mailsac inbox you control. Pattern: <your-inbox>@mailsac.com
# Mailsac auto-creates inboxes on first received message; no signup per inbox.
INVESTOWN_EMAIL=
INVESTOWN_PASSWORD=
INVESTOWN_FIRST_NAME=TESTER
INVESTOWN_LAST_NAME=TEST
# UK virtual number used at signup (any number that worked for you).
INVESTOWN_PHONE=

# --- mailsac (free, sign up at https://mailsac.com) ---
# Account -> API Keys -> Generate. Free tier: 1500 API calls / month.
# Set the inbox above as PRIVATE in mailsac UI so reset links aren't public.
MAILSAC_API_KEY=

# --- Investown Cognito (for API-level password reset submit) ---
